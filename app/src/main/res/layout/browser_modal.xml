<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/modal_backdrop"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
<LinearLayout
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:layout_gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/backdrop"
    android:gravity="bottom"
    android:weightSum="10">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="6">
    <androidx.cardview.widget.CardView
        android:id="@+id/browser_container"
        android:layout_gravity="bottom"
        android:background="@drawable/browser_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="20dp">
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
        <LinearLayout
            android:id="@+id/no_network_indicator"
            android:layout_width="match_parent"
            android:paddingHorizontal="20dp"
            android:layout_height="match_parent"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:layout_gravity="center"
            android:gravity="center">
            <TextView
                android:id="@+id/browser_error_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/darkPurple"
                android:textStyle="bold"
                android:text="No Network Connection"
                />
            <TextView
                android:id="@+id/browser_error_content"
                android:layout_width="wrap_content"
                android:layout_marginVertical="12dp"
                android:textAlignment="center"
                android:layout_height="wrap_content"
                android:textColor="@color/darkPurple"
                android:text="There seems to be an default issue with your network connectivity"
                />
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/page_reload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="reload page"
                />
        </LinearLayout>
        <FrameLayout
            android:id="@+id/browser_loader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primaryBlue"
            android:paddingVertical="1dp">
            <ProgressBar
                android:indeterminate="true"
                android:indeterminateDrawable="@drawable/indeterminate_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="2dp" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>
    </FrameLayout>
</LinearLayout>
</FrameLayout>